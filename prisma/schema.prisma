generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  nickname         String   @default("Anonymous")
  isVerified       Boolean  @default(false)
  avatarUrl        String?
  instituteId      String?
  institute        Institute? @relation(fields: [instituteId], references: [id])
  votes            RatingVote[]
  messages         ChatMessage[]
  createdAt        DateTime @default(now())
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}

model Institute {
  id       String   @id @default(cuid())
  name     String   @unique // ИЭ, ИМГТ, ИЭУ, ИЭП, ИСТ, ИДО, Магистратура
  users    User[]
  messages ChatMessage[]
}

model Teacher {
  id              String   @id @default(cuid())
  name            String
  department      String
  difficultyRating Float    @default(0)
  charismaRating   Float    @default(0)
  votes           RatingVote[]
}

model RatingVote {
  id        String   @id @default(cuid())
  userId    String
  teacherId String
  user      User     @relation(fields: [userId], references: [id])
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  @@unique([userId, teacherId])
}

model Post {
  id        String   @id @default(cuid())
  content   String
  nickname  String   @default("Anonymous")
  likes     Int      @default(0)
  createdAt DateTime @default(now())
}

model ChatMessage {
  id          String   @id @default(cuid())
  content     String
  userId      String
  instituteId String
  user        User     @relation(fields: [userId], references: [id])
  institute   Institute @relation(fields: [instituteId], references: [id])
  createdAt   DateTime @default(now())
}
